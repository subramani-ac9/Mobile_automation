# Mobile Automation Framework Environment Configuration
# Copy this file to .env and update the values according to your setup

# =============================================================================
# PLATFORM CONFIGURATION
# =============================================================================
# Choose platform: 'android' or 'ios'
MOBILE_PLATFORM=android

# =============================================================================
# APPIUM SERVER CONFIGURATION
# =============================================================================
APPIUM_HOST=localhost
APPIUM_PORT=4723

# =============================================================================
# ANDROID CONFIGURATION
# =============================================================================
ANDROID_PLATFORM_NAME=Android
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=13
ANDROID_APP_PACKAGE=com.aoljourney.teacher.app.dev
ANDROID_APP_ACTIVITY=com.aoljourney.teacher.app.MainActivity
# Path to your .apk file (optional if app is already installed)
ANDROID_APP_PATH=

# =============================================================================
# IOS CONFIGURATION
# =============================================================================
IOS_PLATFORM_NAME=iOS
IOS_DEVICE_NAME=iPhone 15
IOS_PLATFORM_VERSION=17.5
IOS_BUNDLE_ID=com.aoljourney.teacher.app

# For real device testing (get UDID with: idevice_id -l)
IOS_UDID=

# For code signing (required for real device testing)
IOS_XCODE_ORG_ID=
IOS_XCODE_SIGNING_ID=iPhone Developer

# Path to your .ipa file (optional if app is already installed)
IOS_APP_PATH=

# =============================================================================
# TEST CREDENTIALS
# =============================================================================
TEST_EMAIL=nivedhas@abovecloud9.ai
TEST_PASSWORD=Admin@ac9
FORGOT_PASSWORD_EMAIL=forgot@example.com

# =============================================================================
# LOCALIZATION TEST DATA
# =============================================================================
# Converted versions of the main test email for international testing
TEST_EMAIL_CYRILLIC=нивeдхас@abovecloud9.ai
TEST_EMAIL_CHINESE=倪维德哈斯@abovecloud9.ai
TEST_EMAIL_JAPANESE=ニヴェドハス@abovecloud9.ai
TEST_EMAIL_ARABIC=نيفيدهاس@abovecloud9.ai

# =============================================================================
# RAPID LOGIN TEST CONFIGURATION
# =============================================================================
# Number of users to test in rapid login scenarios
RAPID_LOGIN_USER_COUNT=5

# Email pattern - {i} will be replaced with user number (1, 2, 3, etc.)
RAPID_LOGIN_EMAIL_PATTERN=autotest+{i}@abovecloud9.ai

# Password pattern - {i} will be replaced with user number (1, 2, 3, etc.)
RAPID_LOGIN_PASSWORD_PATTERN=Admin{i}@123

# Timeout in seconds for rapid login tests
RAPID_LOGIN_TIMEOUT=300

# =============================================================================
# INVALID PASSWORD TEST CONFIGURATION
# =============================================================================
# Number of invalid password attempts to test
INVALID_PASSWORD_USER_COUNT=5

# Invalid password pattern for security testing
INVALID_PASSWORD_PATTERN=Invalid{i}@Wrong

# =============================================================================
# WAIT TIMES & TIMEOUTS
# =============================================================================
IMPLICIT_WAIT=10
EXPLICIT_WAIT=20
DEFAULT_TIMEOUT=30
ELEMENT_TIMEOUT=10

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================
# Test environment settings
TEST_ENVIRONMENT=dev

# Debug mode
DEBUG_MODE=false

# Screenshot settings
CAPTURE_SCREENSHOTS=true
SCREENSHOT_ON_FAILURE=true

# Report settings
GENERATE_ALLURE_REPORT=true
GENERATE_HTML_REPORT=true

# =============================================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT SCENARIOS
# =============================================================================

# Android Emulator Example:
# MOBILE_PLATFORM=android
# ANDROID_DEVICE_NAME=emulator-5554
# ANDROID_PLATFORM_VERSION=13

# Android Real Device Example:
# MOBILE_PLATFORM=android
# ANDROID_DEVICE_NAME=Samsung Galaxy S21
# ANDROID_PLATFORM_VERSION=13

# iOS Simulator Example:
# MOBILE_PLATFORM=ios
# IOS_DEVICE_NAME=iPhone 15 Pro
# IOS_PLATFORM_VERSION=17.5

# iOS Real Device Example:
# MOBILE_PLATFORM=ios
# IOS_DEVICE_NAME=Nivedha's iPhone
# IOS_PLATFORM_VERSION=17.5
# IOS_UDID=00008110-001E29A21EFBA01E
# IOS_XCODE_ORG_ID=ABCD123456
# IOS_XCODE_SIGNING_ID=iPhone Developer: nivedhas@abovecloud9.ai (2UMDFFKV5U)

# Performance Testing Example:
# RAPID_LOGIN_USER_COUNT=10
# RAPID_LOGIN_TIMEOUT=600
# INVALID_PASSWORD_USER_COUNT=10

# CI/CD Pipeline Example:
# TEST_ENVIRONMENT=ci
# CAPTURE_SCREENSHOTS=false
# GENERATE_HTML_REPORT=false
# RAPID_LOGIN_TIMEOUT=180
